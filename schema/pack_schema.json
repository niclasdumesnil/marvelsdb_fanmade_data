{
	"$schema": "http://json-schema.org/draft-04/schema#",
	"additionalProperties": true,
	"description": "JSON Schema for a Marvel Champions pack — derived from Pack.orm.yml",
	"properties": {
		"cgdb_id": {
			"oneOf": [
				{
					"type": "integer"
				},
				{
					"type": "null"
				}
			]
		},
		"code": {
			"minLength": 1,
			"type": "string"
		},
		"creator": {
			"minLength": 1,
			"type": "string"
		},
		"date_release": {
			"oneOf": [
				{
					"type": "string"
				},
				{
					"type": "null"
				}
			]
		},
		"environment": {
			"minLength": 1,
			"type": "string"
		},
		"language": {
			"minLength": 1,
			"type": "string"
		},
		"name": {
			"minLength": 1,
			"type": "string"
		},
		"octgn_id": {
			"minLength": 1,
			"type": "string"
		},
		"pack_type_code": {
			"minLength": 1,
			"type": "string"
		},
		"position": {
			"minimum": 1,
			"type": "integer"
		},
		"size": {
			"oneOf": [
				{
					"minimum": 1,
					"type": "integer"
				},
				{
					"type": "null"
				}
			]
		},
		"status": {
			"minLength": 1,
			"type": "string"
		},
		"theme": {
			"minLength": 1,
			"type": "string"
		},
		"visibility": {
			"oneOf": [
				{
					"type": "string"
				},
				{
					"type": "boolean"
				}
			]
		}
	},
	"required": [
		"code",
		"name",
		"pack_type_code",
		"position",
		"date_release",
		"size"
	],
	"type": "object"
}
