{
	"$schema": "http://json-schema.org/draft-04/schema#",
	"additionalProperties": true,
	"description": "JSON Schema for a Marvel Champions faction — derived from Faction.orm.yml",
	"properties": {
		"code": {
			"minLength": 1,
			"type": "string"
		},
		"is_primary": {
			"type": "boolean"
		},
		"name": {
			"minLength": 1,
			"type": "string"
		},
		"octgn_id": {
			"oneOf": [
				{
					"minLength": 1,
					"type": "string"
				},
				{
					"type": "null"
				}
			]
		}
	},
	"required": [
		"code",
		"name"
	],
	"type": "object"
}
